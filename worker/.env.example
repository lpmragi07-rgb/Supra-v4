# =============================================================
# Worker de Disparo — copie para ".env" e preencha
# =============================================================

# URL do projeto Supabase (mesma do front-end)
SUPABASE_URL=

# Chave service_role (Project Settings > API > service_role).
# ATENÇÃO: ignora o RLS. Mantenha em segredo, uso EXCLUSIVO no servidor.
SUPABASE_SERVICE_ROLE_KEY=

# ---- Evolution API (WhatsApp) ----
# URL base da sua instância Evolution (ex: https://evo.seudominio.com)
EVOLUTION_API_URL=

# API Key da instância (header apikey)
EVOLUTION_API_KEY=

# Nome da instância WhatsApp (não o UUID — use o instanceName)
EVOLUTION_INSTANCE=supra-v4

# Template da mensagem de prospecção (variáveis: {{empresa}}, {{telefone}})
WHATSAPP_MESSAGE_TEMPLATE=Olá! Somos da Supra V4. Identificamos que a {{empresa}} pode se beneficiar das nossas soluções. Podemos conversar?

# ---- Ajustes do disparo (opcionais) ----
# Leads processados por ciclo (recomendado: 3–5 para evitar ban)
BATCH_SIZE=5
# Intervalo entre ciclos (ms)
POLL_INTERVAL_MS=5000
# Delay entre mensagens enviado à Evolution (ms) — mínimo recomendado: 1200
SEND_DELAY_MS=1200
