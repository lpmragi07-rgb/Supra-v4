# =============================================================
# Supabase - copie este arquivo para ".env.local" e preencha
# Painel: https://supabase.com/dashboard > Project Settings > API
# =============================================================

# URL pública do projeto (ex: https://xxxxxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Chave pública "anon" (segura para o navegador, protegida por RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# (Opcional) Chave service_role - USO EXCLUSIVO do Worker/servidor.
# NUNCA prefixe com NEXT_PUBLIC_ e NUNCA exponha no front-end.
# SUPABASE_SERVICE_ROLE_KEY=

# ---- Evolution API (WhatsApp) — servidor apenas ----
# URL base da sua instância Evolution (ex: https://evo.seudominio.com)
EVOLUTION_API_URL=

# API Key da instância (header apikey)
EVOLUTION_API_KEY=

# Chave global (opcional, para criar instância automaticamente)
# EVOLUTION_GLOBAL_KEY=

# Nome da instância WhatsApp
EVOLUTION_INSTANCE=supra-v4
